generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
	id Int @id @default(autoincrement())
	name String
	email String? @unique
	login String? @unique
	avatarUrl String?
	accessToken String
	githubId Int @unique
	repos Repo[]
	createdat DateTime @default(now())
}

model Repo {
	id  Int @id @default(autoincrement()) 
	repoId Int @unique
	userId Int
	repo String @unique
	user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade )
	event Event[]
}

model Event {
	id Int @id @default(autoincrement())
	repoId Int
	message String
	branch String
	repo Repo @relation(fields: [repoId], references: [id])
	createdat DateTime @default(now())
}
